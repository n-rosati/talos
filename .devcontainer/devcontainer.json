{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "ClusterTool Cluster",
  "image": "ghcr.io/trueforge-org/devcontainer:3.0.2@sha256:987051ee063d3e1c6465882ac2359df5c7b18df2fbea2483c1aa260959e001da",
  "postCreateCommand": {
