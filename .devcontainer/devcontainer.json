{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "ClusterTool Cluster",
  "image": "ghcr.io/trueforge-org/devcontainer:4.1.1@sha256:a37275a4c9d7bafa7752bb9eface12627b5b32e98f59fcdfca618e813882600e",
  "postCreateCommand": {
    "setup": "bash ${containerWorkspaceFolder}/.devcontainer/postCreateCommand.sh"
  },
  "postStartCommand": {
    "git": "git config --global --add safe.directory ${containerWorkspaceFolder}"
  },
  "updateRemoteUserUID": false,
  "runArgs": [
    "--privileged"
  ],
  "containerEnv": {
    "TALOSCONFIG": "/workspaces/talos/clusters/main/talos/generated/talosconfig",
    "KUBECONFIG": "/workspaces/talos/clusters/main/talos/generated/kubeconfig"
  }
}